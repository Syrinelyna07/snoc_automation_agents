# Persistence (SQLite is the safe local default; PostgreSQL is intended for deployment)
DATABASE_URL=sqlite:///./snoc_agent.db
# Safe default keeps the original imperative processor. Set to langgraph only
# after running the parity suite in the target environment.
WORKFLOW_ENGINE=langgraph
# Optional isolation when multiple checkouts share one Docker host.
SNOC_COMPOSE_PROJECT_NAME=snoc-langgraph
SNOC_DASHBOARD_PORT=8502
SNOC_POSTGRES_VOLUME=snoc_langgraph_postgres_data

# IMAP
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_SSL=true
IMAP_POLL_SECONDS=30
# Keep a dedicated header filter for acceptance runs so unrelated inbox traffic
# is never consumed. Use ALL only after a deliberate production review.
IMAP_SEARCH_CRITERION=HEADER X-SNOC-Test-Run-ID "docker-e2e"

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=snoc-agent@example.invalid
# Optional inbound self-message identity; defaults to SMTP_FROM_ADDRESS.
SYSTEM_EMAIL_ADDRESS=
SMTP_SSL=true
SMTP_STARTTLS=false

# Authorization / escalation
AUTHORIZED_SENDERS=manager@example.test
ESCALATION_RECIPIENT=human-support@example.invalid
# Optional credentials used only by scripts/docker_mail_journey.py to act as
# an external human. The username falls back to the sole authorized sender.
SENDER_USERNAME=
SENDER_PASSWORD=
SENDER_IMAP_MAILBOX=[Gmail]/All Mail

# Model provider. If omitted, LLM_BASE_URL keeps selecting openai_compatible;
# otherwise the deterministic demo backend remains the backward-compatible default.
LLM_PROVIDER=vllm

# Primary Qwen/Gemma vLLM deployments. The key is shared by the two configured
# servers, remains environment-only, and is never written to model audit rows.
VLLM_API_KEY=replace_me
VLLM_QWEN_BASE_URL=https://qwen.example.com/v1
VLLM_QWEN_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
VLLM_GEMMA_BASE_URL=https://gemma.example.com/v1
VLLM_GEMMA_MODEL=google/gemma-4-12B-it
VLLM_ANALYZER_DEPLOYMENT=gemma
VLLM_VERIFIER_DEPLOYMENT=gemma
VLLM_REQUEST_TIMEOUT_SECONDS=120
VLLM_MAX_RETRIES=2
VLLM_RETRY_BASE_SECONDS=2
VLLM_USE_JSON_SCHEMA=true
VLLM_ALLOW_JSON_OBJECT_FALLBACK=true
VLLM_ALLOW_PROMPT_JSON_FALLBACK=true
VLLM_MAX_OUTPUT_TOKENS_ANALYZER=4096
VLLM_MAX_OUTPUT_TOKENS_VERIFIER=4096
RUN_VLLM_LIVE_TESTS=false

# Generic OpenAI-compatible local model server (llama.cpp server, etc.). These are
# compatibility aliases for Hugging Face when the corresponding HF_* value is empty.
LLM_BASE_URL=
LLM_API_KEY=
ANALYZER_MODEL=Qwen2.5-7B-Instruct
VERIFIER_MODEL=Qwen3-8B
ANALYZER_TEMPERATURE=0.0
VERIFIER_TEMPERATURE=0.0
# Optional raw self-report gates; set only from an offline calibration decision.
# ANALYZER_MIN_RAW_CONFIDENCE=0.85
# VERIFIER_MIN_RAW_CONFIDENCE=0.85
QWEN3_ENABLE_THINKING=false
QWEN3_SEND_THINKING_PARAMETER=true
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_SUPPORTS_LOGPROBS=false
LLM_JSON_SCHEMA_MODE=true
MODEL_QUANTIZATION=

# Hugging Face Inference Providers. HF_* values take precedence over aliases above.
# Create a fine-grained token with "Make calls to Inference Providers" permission.
HF_TOKEN=hf_replace_me
HF_ROUTER_BASE_URL=https://router.huggingface.co/v1
HF_ANALYZER_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_VERIFIER_MODEL=Qwen/Qwen3-8B
HF_PROVIDER_POLICY=cheapest
HF_ANALYZER_PROVIDER=
HF_VERIFIER_PROVIDER=
HF_ROUTING_SUFFIX_ENABLED=true
HF_REQUEST_TIMEOUT_SECONDS=120
HF_MAX_RETRIES=3
HF_RETRY_BASE_SECONDS=2
HF_USE_JSON_SCHEMA=true
HF_ALLOW_JSON_OBJECT_FALLBACK=true
HF_ALLOW_PROMPT_JSON_FALLBACK=true
HF_MAX_OUTPUT_TOKENS_ANALYZER=1200
HF_MAX_OUTPUT_TOKENS_VERIFIER=700
# Advanced provider-specific request fields only. Core request fields cannot be overridden.
HF_EXTRA_BODY_JSON={}
HF_RUN_BUDGET_USD=20
HF_STOP_BEFORE_BUDGET_USD=19
HF_REQUIRE_BUDGET_CONFIRMATION=false
# Unknown-cost calls continue with warnings and cannot be guaranteed by the local USD cap.
HF_ALLOW_UNKNOWN_COST=true
HF_MODEL_LIST_CACHE_TTL_SECONDS=300
HF_MODEL_LIST_CACHE_PATH=var/cache/hf_models.json
HF_LIVE_TEST_MAX_COST_USD=0.10
RUN_HF_LIVE_TESTS=false
EVALUATION_CHECKPOINT_EVERY=10

# Business API. Live execution is deliberately disabled by default.
BUSINESS_API_BASE_URL=
BUSINESS_API_TOKEN=
DRY_RUN=true
# Opt in only for controlled mailbox tests: telecom actions stay mocked, while
# clarification/completion/escalation messages may be delivered through SMTP.
DRY_RUN_SEND_EMAILS=false
BUSINESS_API_TIMEOUT_SECONDS=15
BUSINESS_API_MAX_RETRIES=2
BUSINESS_API_IDEMPOTENCY_GUARANTEED=false
BUSINESS_API_VPN_PATH=/create-account
BUSINESS_API_OTP_PATH=/update-otp/{pdv_code}/{new_phone}
BUSINESS_API_UNBLOCK_PATH=/unlock-account/{pdv_code}
BUSINESS_API_RESET_PATH=/reset-password/{pdv_code}
# Comma-separated keys explicitly approved for the VPN JSON body; empty is safest.
BUSINESS_API_VPN_ALLOWED_ADDITIONAL_FIELDS=

# Validation / workflow
PDV_PATTERN=^\d{8}$
PHONE_PATTERN=^\+?\d{9,15}$
MAX_CLARIFICATION_ROUNDS=1
STORE_RAW_EML=true
RAW_EML_DIRECTORY=var/raw_eml
LOG_EMAIL_CONTENT=false
MAX_RAW_EMAIL_BYTES=10485760
MAX_TEXT_PART_BYTES=1048576
MAX_HTML_PART_BYTES=2097152
MAX_ATTACHMENT_COUNT=20
MAX_ATTACHMENT_BYTES=5242880
MAX_MODEL_CONTEXT_CHARACTERS=24000
MAX_LATEST_MESSAGE_CHARACTERS=12000
MAX_RELEVANT_THREAD_CHARACTERS=4000
