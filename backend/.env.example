# SNOC safety-first agent configuration.
# Copy to backend/.env locally. Keep all real values out of version control.

APP_ENV=development
LOG_LEVEL=INFO
DRY_RUN=true
AUTO_EXECUTION_ENABLED=false
TIMEZONE=UTC

DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true
IMAP_POLL_SECONDS=30
IMAP_MAX_MESSAGE_BYTES=10485760
IMAP_SEARCH_CRITERION=ALL

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=true
SMTP_MAX_RETRIES=5
ESCALATION_RECIPIENT=

AUTHORIZED_SENDERS=
LDAP_ENABLED=false
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_ALLOWED_GROUPS=

LLM_PROVIDER=vllm
ANALYZER_LLM_BASE_URL=
ANALYZER_LLM_API_KEY=
ANALYZER_LLM_MODEL=
ANALYZER_LLM_ENDPOINT=/v1/chat/completions

VERIFIER_LLM_BASE_URL=
VERIFIER_LLM_API_KEY=
VERIFIER_LLM_MODEL=
VERIFIER_LLM_ENDPOINT=/v1/chat/completions

SQLCODER_ENABLED=false
SQLCODER_BASE_URL=
SQLCODER_API_KEY=
SQLCODER_MODEL=
SQLCODER_ENDPOINT=/v1/completions

LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_READ_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=1200
ANALYZER_TEMPERATURE=0
VERIFIER_TEMPERATURE=0
LLM_RESPONSE_FORMAT_MODE=auto

BUSINESS_API_BASE_URL=
BUSINESS_API_BEARER_TOKEN=
BUSINESS_API_TIMEOUT_SECONDS=30
BUSINESS_API_IDEMPOTENCY_HEADER=Idempotency-Key
BUSINESS_API_CREATE_VPN_PATH=
BUSINESS_API_UPDATE_OTP_PATH=
BUSINESS_API_UNLOCK_ACCOUNT_PATH=
BUSINESS_API_RESET_PASSWORD_PATH=

API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_PUBLIC_KEY=

MAX_CLARIFICATION_ROUNDS=1
MAX_CONTEXT_CHARACTERS=24000
REQUIRE_VERIFIER=true
REQUIRE_DIRECT_EVIDENCE=true
